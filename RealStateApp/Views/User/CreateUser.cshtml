@model CreateClientOrAgentViewModel
@{
    ViewData["Title"] = "Crear usuario";
}

<style>
    body {
        background: #f4f6fb;
    }

    .form-card {
        border-radius: 15px;
        animation: fadeIn 0.6s ease-in-out;
    }

    .form-header {
        background: linear-gradient(135deg, #4e73df, #1cc88a);
        color: white;
        border-radius: 15px 15px 0 0;
        padding: 20px;
        text-align: center;
    }

    .form-control, .form-select {
        border-radius: 10px;
        padding-left: 40px;
    }

    .input-group {
        position: relative;
    }

    .input-icon {
        position: absolute;
        left: 12px;
        top: 50%;
        transform: translateY(-50%);
        color: #6c757d;
    }

    .btn-success {
        border-radius: 10px;
        background: linear-gradient(135deg, #1cc88a, #4e73df);
        border: none;
        transition: 0.3s;
    }

    .btn-success:hover {
        transform: scale(1.05);
    }

    .section-title {
        font-size: 14px;
        font-weight: 600;
        color: #6c757d;
        margin-top: 20px;
    }

    @@keyframes fadeIn {
        from { opacity: 0; transform: translateY(15px); }
        to { opacity: 1; transform: translateY(0); }
    }
</style>

<div class="d-flex justify-content-center py-5">
    <div class="col-md-6 col-lg-5">

        @if (ViewBag.Message != null)
        {
            <div class="alert alert-info alert-dismissible fade show text-center">
                @if (ViewBag.Message is string)
                {
                    @Html.Raw(ViewBag.Message.Replace("\n", "<br />"))
                }
                else
                {
                    foreach (var line in ViewBag.Message)
                    {
                        <p>@line</p>
                    }
                }
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }

        <div class="card shadow-lg form-card">

            <div class="form-header">
                <h3 class="mb-0">👤 Crear usuario</h3>
                <small>Completa la información</small>
            </div>

            <div class="card-body px-4">

                <form asp-controller="User" asp-action="CreateUser" method="post" enctype="multipart/form-data">

                    <div class="section-title">Información personal</div>

                    <div class="mt-2 input-group">
                        <i class="bi bi-person input-icon"></i>
                        <input class="form-control" asp-for="FirstName" placeholder="Nombre" />
                    </div>
                    <span class="text-danger" asp-validation-for="FirstName"></span>

                    <div class="mt-2 input-group">
                        <i class="bi bi-person-badge input-icon"></i>
                        <input class="form-control" asp-for="LastName" placeholder="Apellidos" />
                    </div>
                    <span class="text-danger" asp-validation-for="LastName"></span>

                    <div class="mt-2 input-group">
                        <i class="bi bi-envelope input-icon"></i>
                        <input class="form-control" asp-for="Email" placeholder="Email" />
                    </div>
                    <span class="text-danger" asp-validation-for="Email"></span>

                    <div class="mt-2 input-group">
                        <i class="bi bi-credit-card input-icon"></i>
                        <input class="form-control" asp-for="IdentityCardNumber" placeholder="Cédula" />
                    </div>
                    <span class="text-danger" asp-validation-for="IdentityCardNumber"></span>

                    <div class="mt-2 input-group">
                        <i class="bi bi-telephone input-icon"></i>
                        <input class="form-control" asp-for="PhoneNumber" placeholder="Teléfono" />
                    </div>
                    <span class="text-danger" asp-validation-for="PhoneNumber"></span>

                    <div class="mt-3">
                        <label class="form-label">Imagen de perfil</label>
                        <input class="form-control" asp-for="ProfileImage" />
                        <span class="text-danger" asp-validation-for="ProfileImage"></span>
                    </div>

                    <div class="section-title">Cuenta</div>

                    <div class="mt-2 input-group">
                        <i class="bi bi-person-circle input-icon"></i>
                        <input class="form-control" asp-for="UserName" placeholder="Usuario" />
                    </div>
                    <span class="text-danger" asp-validation-for="UserName"></span>

                    <div class="mt-2 input-group">
                        <i class="bi bi-lock input-icon"></i>
                        <input type="password" class="form-control" asp-for="Password" placeholder="Contraseña" />
                    </div>
                    <span class="text-danger" asp-validation-for="Password"></span>

                    <div class="mt-2 input-group">
                        <i class="bi bi-lock-fill input-icon"></i>
                        <input type="password" class="form-control" asp-for="ConfirmPassword" placeholder="Confirmar contraseña" />
                    </div>
                    <span class="text-danger" asp-validation-for="ConfirmPassword"></span>

                    <div class="mt-3">
                        <label class="form-label">Rol</label>
                        <select class="form-select" asp-for="Role" asp-items="ViewBag.Roles"></select>
                        <span class="text-danger" asp-validation-for="Role"></span>
                    </div>

                    <div class="d-flex justify-content-center mt-4">
                        <button class="btn btn-success w-100 fw-semibold" type="submit">
                            Crear usuario
                        </button>
                    </div>

                </form>
            </div>
        </div>

    </div>
</div>