@model LoginViewModel
@{
    ViewData["Title"] = "Home Page";
    Layout = "_LayoutBase";
}

<style>
    body {
        background: linear-gradient(135deg, #4e73df, #1cc88a);
        font-family: 'Segoe UI', sans-serif;
    }

    .login-container {
        min-height: 100vh;
    }

    .login-card {
        border-radius: 20px;
        backdrop-filter: blur(10px);
        background: rgba(255, 255, 255, 0.9);
        animation: fadeIn 0.7s ease;
    }

    .login-header h2 {
        font-weight: 700;
    }

    .form-control {
        border-radius: 12px;
        padding-left: 45px;
        height: 45px;
    }

    .input-group {
        position: relative;
    }

    .input-icon {
        position: absolute;
        left: 15px;
        top: 50%;
        transform: translateY(-50%);
        color: #6c757d;
        font-size: 1.1rem;
    }

    .btn-primary {
        border-radius: 12px;
        background: linear-gradient(135deg, #4e73df, #1cc88a);
        border: none;
        height: 45px;
        font-weight: 600;
        transition: 0.3s;
    }

    .btn-primary:hover {
        transform: translateY(-2px);
        box-shadow: 0 6px 18px rgba(0,0,0,0.2);
    }

    .link {
        font-size: 0.9rem;
        color: #6c757d;
    }

    .link:hover {
        color: #4e73df;
    }

    .alert {
        border-radius: 10px;
    }

    @@keyframes fadeIn {
        from { opacity: 0; transform: translateY(20px);}
        to { opacity: 1; transform: translateY(0);}
    }
</style>

<div class="d-flex justify-content-center align-items-center login-container">
    <div class="col-md-4">

        @if (ViewBag.Message != null)
        {
            <div class="alert alert-info alert-dismissible fade show text-center">
                @if (ViewBag.Message is string)
                {
                    @Html.Raw(ViewBag.Message.Replace("\n", "<br />"))
                }
                else
                {
                    foreach (var line in ViewBag.Message)
                    {
                        <p>@line</p>
                    }
                }
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }

        <div class="card shadow-lg login-card p-4">

            <div class="login-header text-center mb-3">
                <h2 class="text-primary">RealState App</h2>
                <p class="text-muted">Accede a tu cuenta</p>
            </div>

            <form asp-controller="Login" asp-action="LogIn" method="post">

                <!-- Usuario -->
                <div class="mt-3 input-group">
                    <i class="bi bi-person input-icon"></i>
                    <input class="form-control" asp-for="UserName" placeholder="Usuario" />
                </div>
                <span class="text-danger" asp-validation-for="UserName"></span>

                <!-- Password -->
                <div class="mt-3 input-group">
                    <i class="bi bi-lock input-icon"></i>
                    <input type="password" class="form-control" asp-for="Password" placeholder="Contraseña" />
                </div>
                <span class="text-danger" asp-validation-for="Password"></span>

                <!-- Botón -->
                <div class="mt-4">
                    <button class="btn btn-primary w-100">
                        Iniciar sesión
                    </button>
                </div>
            </form>

            <!-- Links -->
            <div class="text-center mt-3">
                <a asp-controller="Login" asp-action="ForgotPassword" class="link">
                    ¿Olvidaste tu contraseña?
                </a>
            </div>

        </div>

    </div>
</div>