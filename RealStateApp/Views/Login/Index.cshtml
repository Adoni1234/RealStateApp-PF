@model LoginViewModel
@{
    ViewData["Title"] = "Home Page";
    Layout = "_LayoutBase";
}

<style>
    body {
        background: linear-gradient(135deg, #4e73df, #1cc88a);
    }

    .login-card {
        border-radius: 15px;
        overflow: hidden;
        animation: fadeIn 0.8s ease-in-out;
    }

    .login-header {
        background: transparent;
        border-bottom: none;
    }

    .form-control {
        border-radius: 10px;
        padding-left: 40px;
    }

    .input-icon {
        position: absolute;
        left: 12px;
        top: 50%;
        transform: translateY(-50%);
        color: #6c757d;
    }

    .input-group {
        position: relative;
    }

    .btn-primary {
        border-radius: 10px;
        transition: all 0.3s ease;
    }

    .btn-primary:hover {
        transform: scale(1.05);
        box-shadow: 0 5px 15px rgba(0,0,0,0.2);
    }

    a {
        text-decoration: none;
    }

    a:hover {
        text-decoration: underline;
    }

@@keyframes fadeIn {
            from {
            opacity: 0;
            transform: translateY(20px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }
</style>

<div class="d-flex justify-content-center align-items-center min-vh-100">
    <div class="col-md-4">

        @if (ViewBag.Message != null)
        {
            <div class="alert alert-info alert-dismissible fade show text-center" role="alert">
                @if (ViewBag.Message is string)
                {
                    @Html.Raw(ViewBag.Message.Replace("\n", "<br />"))
                }
                else
                {
                    foreach (var line in ViewBag.Message)
                    {
                        <p>@line</p>
                    }
                }
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }

        <div class="card shadow-lg login-card">
            <div class="card-header login-header text-center pt-4">
                <h2 class="fw-bold text-primary">RealState App</h2>
                <p class="text-muted mb-0">Bienvenido de nuevo</p>
            </div>

            <div class="card-body px-4 pb-4">
                <form asp-controller="Login" asp-action="LogIn" method="post">

                    <div class="mt-3 input-group">
                        <i class="bi bi-person input-icon"></i>
                        <input class="form-control" asp-for="UserName" placeholder="Nombre de usuario" />
                    </div>
                    <span class="text-danger" asp-validation-for="UserName"></span>

                    <div class="mt-3 input-group">
                        <i class="bi bi-lock input-icon"></i>
                        <input type="password" class="form-control" asp-for="Password" placeholder="Contraseña" />
                    </div>
                    <span class="text-danger" asp-validation-for="Password"></span>

                    <div class="d-flex justify-content-center mt-4">
                        <button class="btn btn-primary w-100 fw-semibold" type="submit">
                            Iniciar sesión
                        </button>
                    </div>
                </form>

                <div class="text-center mt-3">
                    <a asp-controller="Login" asp-action="ForgotPassword" class="text-muted">
                        ¿Olvidaste tu contraseña?
                    </a>
                </div>
            </div>
        </div>

    </div>
</div>