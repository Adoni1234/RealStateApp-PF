@model ForgotPasswordRequestViewModel
@{
    ViewData["Title"] = "Forgot password";
    Layout = "_LayoutBase";
}

<style>
    body {
        background: linear-gradient(135deg, #1cc88a, #4e73df);
    }

    .forgot-card {
        border-radius: 15px;
        overflow: hidden;
        animation: fadeIn 0.6s ease-in-out;
    }

    .forgot-header {
        background: transparent;
        border-bottom: none;
    }

    .form-control {
        border-radius: 10px;
        padding-left: 40px;
    }

    .input-group {
        position: relative;
    }

    .input-icon {
        position: absolute;
        left: 12px;
        top: 50%;
        transform: translateY(-50%);
        color: #6c757d;
    }

    .btn {
        border-radius: 10px;
        transition: 0.3s;
    }

    .btn-primary {
        background: linear-gradient(135deg, #4e73df, #1cc88a);
        border: none;
    }

    .btn-primary:hover {
        transform: scale(1.05);
    }

    a {
        text-decoration: none;
    }

    a:hover {
        text-decoration: underline;
    }

    @@keyframes fadeIn {
        from { opacity: 0; transform: translateY(15px); }
        to { opacity: 1; transform: translateY(0); }
    }
</style>

<div class="d-flex justify-content-center align-items-center min-vh-100">
    <div class="col-12 col-md-4">

        @if (ViewBag.Message != null)
        {
            <div class="alert alert-info alert-dismissible fade show text-center" role="alert">
                @if (ViewBag.Message is string)
                {
                    @Html.Raw(ViewBag.Message.Replace("\n", "<br />"))
                }
                else
                {
                    foreach (var line in ViewBag.Message)
                    {
                        <p>@line</p>
                    }
                }
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }

        <div class="card shadow-lg forgot-card">
            <div class="card-header forgot-header text-center pt-4">
                <h3 class="fw-bold text-primary">Recuperar contraseña</h3>
                <p class="text-muted">Ingresa tu usuario para continuar</p>
            </div>

            <div class="card-body px-4 pb-4">
                <form asp-controller="Login" asp-action="ForgotPassword" method="POST">

                    <div class="mt-3 input-group">
                        <i class="bi bi-person input-icon"></i>
                        <input class="form-control" asp-for="UserName" placeholder="Nombre de usuario" />
                    </div>
                    <span asp-validation-for="UserName" class="text-danger"></span>

                    <div class="d-flex justify-content-between mt-4">
                        <a asp-controller="Login" asp-action="Index" class="btn btn-outline-secondary">
                            ← Volver
                        </a>

                        <button type="submit" class="btn btn-primary px-4">
                            Continuar
                        </button>
                    </div>

                </form>
            </div>
        </div>

    </div>
</div>