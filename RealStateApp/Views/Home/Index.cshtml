@using RealStateApp.Core.Domain.Common
@model HomeIndexViewModel

@{
    ViewData["Title"] = "Listado de Propiedades";
}

<style>
    body {
        background: #f5f7fb;
    }

    .sidebar {
        position: sticky;
        top: 20px;
    }

    .filter-card {
        border-radius: 15px;
    }

    .filter-title {
        font-weight: 600;
    }

    .form-control, .form-select {
        border-radius: 10px;
    }

    .btn {
        border-radius: 10px;
    }

    .btn-primary {
        background: linear-gradient(135deg, #4e73df, #1cc88a);
        border: none;
    }

    .btn-primary:hover {
        transform: scale(1.03);
    }

    .properties-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 15px;
    }

    .properties-header h4 {
        font-weight: 600;
    }

    .badge-results {
        background: #e9ecef;
        padding: 5px 10px;
        border-radius: 10px;
    }
</style>

<div class="container-fluid">
    <div class="row">

        <!-- ==== SIDEBAR ==== -->
        <div class="col-md-3 col-lg-3 mb-4 sidebar">
            <div class="card shadow-sm filter-card">
                <div class="card-body">

                    <h5 class="filter-title mb-3">🔍 Filtros</h5>

                    <form asp-controller="Home" asp-action="Index" method="get">

                        <input type="hidden" asp-for="Filters.OnlyFavorites" value="@Model.Filters.OnlyFavorites" />

                        <!-- Tipo -->
                        <div class="mb-3">
                            <label class="form-label">Tipo</label>
                            <select class="form-select" name="Filters.SelectedPropertyTypeId">
                                <option value="">Todos</option>
                                @foreach (var type in Model.PropertyTypes)
                                {
                                    <option value="@type.Id" selected="@(type.Id == Model.Filters.SelectedPropertyTypeId)">
                                        @type.Name
                                    </option>
                                }
                            </select>
                        </div>

                        <!-- Código -->
                        <div class="mb-3">
                            <label class="form-label">Código</label>
                            <input type="text" name="Filters.PropertyCode" class="form-control"
                                   value="@Model.Filters.PropertyCode" placeholder="Ej: APT-001" />
                        </div>

                        <!-- Precio -->
                        <div class="row">
                            <div class="col">
                                <input type="number" name="Filters.MinValue"
                                       class="form-control mb-2"
                                       placeholder="Min $" value="@Model.Filters.MinValue" />
                            </div>
                            <div class="col">
                                <input type="number" name="Filters.MaxValue"
                                       class="form-control mb-2"
                                       placeholder="Max $" value="@Model.Filters.MaxValue" />
                            </div>
                        </div>

                        <!-- Habitaciones y baños -->
                        <div class="row">
                            <div class="col">
                                <input type="number" name="Filters.Rooms"
                                       class="form-control mb-2"
                                       placeholder="Habitaciones"
                                       value="@Model.Filters.Rooms" />
                            </div>
                            <div class="col">
                                <input type="number" name="Filters.Bathrooms"
                                       class="form-control mb-2"
                                       placeholder="Baños"
                                       value="@Model.Filters.Bathrooms" />
                            </div>
                        </div>

                        <div class="d-grid gap-2 mt-3">
                            <button type="submit" class="btn btn-primary">Buscar</button>
                            <a asp-action="Index" class="btn btn-outline-secondary">Limpiar</a>
                        </div>

                    </form>
                </div>
            </div>
        </div>

        <!-- ==== LISTADO ==== -->
        <div class="col-md-9 col-lg-9">

            <div class="properties-header">
                <h4>🏠 Propiedades disponibles</h4>
                <span class="badge-results">
                    @Model.Properties?.Count() resultados
                </span>
            </div>

            <div class="row g-4">

                @if (Model.Properties == null || !Model.Properties.Any())
                {
                    <div class="col-12">
                        <div class="alert alert-info text-center">
                            No se encontraron propiedades con los filtros seleccionados.
                        </div>
                    </div>
                }
                else
                {
                    @foreach (var prop in Model.Properties)
                    {
                        <div class="col-md-6 col-lg-4">
                            @if (User.IsInRole(nameof(Roles.Client)))
                            {
                                @await Html.PartialAsync("_PropertyCardClient", prop)
                            }
                            else
                            {
                                @await Html.PartialAsync("_PropertyCard", prop)
                            }
                        </div>
                    }
                }

            </div>
        </div>

    </div>
</div>