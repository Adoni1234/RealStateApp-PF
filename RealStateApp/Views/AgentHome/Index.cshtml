@model List<UserViewModel>

@{
    ViewData["Title"] = "Agentes";
}

<style>
    body {
        background: #f5f7fb;
    }

    .search-box {
        max-width: 400px;
    }

    .card-agent {
        border-radius: 15px;
        transition: all 0.3s ease;
        overflow: hidden;
        position: relative;
    }

    .card-agent:hover {
        transform: translateY(-8px);
        box-shadow: 0 10px 25px rgba(0,0,0,0.15);
    }

    .agent-img {
        width: 110px;
        height: 110px;
        object-fit: cover;
        border: 4px solid #fff;
        margin-top: -55px;
        background: white;
    }

    .card-top {
        height: 80px;
        background: linear-gradient(135deg, #4e73df, #1cc88a);
    }

    .card-body h5 {
        font-weight: 600;
    }

    .agent-info {
        font-size: 14px;
        color: #6c757d;
    }

    .card-agent:hover .btn-view {
        opacity: 1;
        transform: translateY(0);
    }

    .btn-view {
        transition: 0.3s;
        opacity: 0;
        transform: translateY(10px);
    }
</style>

<h2 class="mb-4 fw-bold">Agentes</h2>

<form method="get" asp-action="Index" class="mb-4 d-flex justify-content-center">
    <div class="input-group search-box">
        <input type="text" name="name" value="@Context.Request.Query["search"]"
               class="form-control rounded-start-pill"
               placeholder="Buscar agente por nombre..." />
        <button class="btn btn-primary rounded-end-pill px-4" type="submit">
            Buscar
        </button>
    </div>
</form>

<div class="row row-cols-1 row-cols-md-3 row-cols-lg-4 g-4">
    @foreach (var agent in Model)
    {
        <div class="col">
            <a asp-action="Properties" asp-route-AgentId="@agent.Id"
               class="text-decoration-none text-dark">

                <div class="card card-agent shadow-sm text-center">

                    <!-- Header con gradiente -->
                    <div class="card-top"></div>

                    <!-- Imagen -->
                    <div class="d-flex justify-content-center">
                        <img src="@agent.ProfileImagePath"
                             class="rounded-circle agent-img" />
                    </div>

                    <div class="card-body pt-2">
                        <h5 class="card-title mb-1">
                            @agent.FirstName @agent.LastName
                        </h5>

                        <p class="agent-info mb-1">
                            <i class="bi bi-envelope"></i> @agent.Email
                        </p>

                        @if (!string.IsNullOrEmpty(agent.PhoneNumber))
                        {
                            <p class="agent-info">
                                <i class="bi bi-telephone"></i> @agent.PhoneNumber
                            </p>
                        }

                        <!-- Botón oculto -->
                        <div class="mt-3">
                            <span class="btn btn-outline-primary btn-sm btn-view">
                                Ver propiedades
                            </span>
                        </div>
                    </div>

                </div>

            </a>
        </div>
    }
</div>