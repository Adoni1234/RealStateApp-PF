@model List<UserViewModel>

@{
    ViewData["Title"] = "Agentes";
}

<style>
    body {
        background: #f4f6fb;
        font-family: 'Segoe UI', sans-serif;
    }

    /* ===== Buscador ===== */
    .search-box {
        max-width: 420px;
    }

    .search-box input {
        border-radius: 30px 0 0 30px;
        padding-left: 20px;
    }

    .search-box button {
        border-radius: 0 30px 30px 0;
        font-weight: 600;
    }

    /* ===== Cards ===== */
    .card-agent {
        border-radius: 18px;
        transition: all 0.3s ease;
        overflow: hidden;
        position: relative;
        border: none;
    }

    .card-agent:hover {
        transform: translateY(-10px);
        box-shadow: 0 12px 30px rgba(0,0,0,0.15);
    }

    /* Header */
    .card-top {
        height: 90px;
        background: linear-gradient(135deg, #4e73df, #1cc88a);
    }

    /* Imagen */
    .agent-img {
        width: 110px;
        height: 110px;
        object-fit: cover;
        border: 4px solid #fff;
        margin-top: -55px;
        background: white;
        transition: 0.3s;
    }

    .card-agent:hover .agent-img {
        transform: scale(1.05);
    }

    /* Nombre */
    .card-body h5 {
        font-weight: 700;
    }

    /* Info */
    .agent-info {
        font-size: 13px;
        color: #6c757d;
    }

    /* Botón */
    .btn-view {
        transition: 0.3s;
        opacity: 0;
        transform: translateY(10px);
        border-radius: 20px;
        font-weight: 500;
    }

    .card-agent:hover .btn-view {
        opacity: 1;
        transform: translateY(0);
    }

    /* Badge estado (visual extra) */
    .agent-badge {
        position: absolute;
        top: 12px;
        right: 12px;
        background: #1cc88a;
        color: white;
        font-size: 11px;
        padding: 4px 10px;
        border-radius: 20px;
    }

    /* Hover link limpio */
    a {
        text-decoration: none;
    }

    a:hover {
        text-decoration: none;
    }
</style>

<h2 class="mb-4 fw-bold"> Agentes disponibles</h2>

<form method="get" asp-action="Index" class="mb-4 d-flex justify-content-center">
    <div class="input-group search-box shadow-sm">
        <input type="text" name="name" value="@Context.Request.Query["search"]"
               class="form-control"
               placeholder="Buscar agente por nombre..." />
        <button class="btn btn-primary px-4" type="submit">
            🔍 Buscar
        </button>
    </div>
</form>

<div class="row row-cols-1 row-cols-md-3 row-cols-lg-4 g-4">

    @if (Model == null || !Model.Any())
    {
        <div class="col-12">
            <div class="text-center p-5 bg-white rounded shadow-sm">
                <h5> No hay agentes disponibles</h5>
                <p class="text-muted">Intenta con otra búsqueda</p>
            </div>
        </div>
    }
    else
    {
        @foreach (var agent in Model)
        {
            <div class="col">
                <a asp-action="Properties" asp-route-AgentId="@agent.Id">

                    <div class="card card-agent shadow-sm text-center">

                        <!-- Badge -->
                        <span class="agent-badge">Activo</span>

                        <!-- Header -->
                        <div class="card-top"></div>

                        <!-- Imagen -->
                        <div class="d-flex justify-content-center">
                            <img src="@agent.ProfileImagePath"
                                 class="rounded-circle agent-img" />
                        </div>

                        <div class="card-body pt-2">

                            <h5 class="mb-1">
                                @agent.FirstName @agent.LastName
                            </h5>

                            <p class="agent-info mb-1">
                                <i class="bi bi-envelope"></i> @agent.Email
                            </p>

                            @if (!string.IsNullOrEmpty(agent.PhoneNumber))
                            {
                                <p class="agent-info">
                                    <i class="bi bi-telephone"></i> @agent.PhoneNumber
                                </p>
                            }

                            <!-- Botón -->
                            <div class="mt-3">
                                <span class="btn btn-outline-primary btn-sm btn-view">
                                    Ver propiedades
                                </span>
                            </div>

                        </div>

                    </div>

                </a>
            </div>
        }
    }

</div>